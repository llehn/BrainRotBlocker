{
  // BrainRotDoctor configuration. Edit this file to add or change rules
  // without recompiling the application.
  //
  // A "rule" is what to block plus when to block it:
  //   - "sites": the things it blocks. Pick from the built-in catalog with
  //       "catalogId" (canonical label + matching), or add a custom site with a
  //       "label" + "url" (+ optional "includeSubpaths": true to also match pages
  //       beneath it).
  //   - "allowanceMinutes": minutes of access allowed per hour. Omit it to block
  //       the sites completely while the rule is active.
  //   - "allDay": true, or set "allDay": false with a "from"/"to" 24-hour window
  //       (a window whose "to" is earlier than "from" wraps past midnight).
  //   - "days": which weekdays the rule applies on. Omit for every day.

  "rules": [
    {
      "id": "short-video",
      "name": "Short video",
      "allowanceMinutes": 5,
      "allDay": true,
      "sites": [
        { "catalogId": "yt-shorts" },
        { "catalogId": "ig-reels" },
        { "catalogId": "fb-reels" },
        { "catalogId": "tiktok" }
      ]
    },
    {
      "id": "feeds",
      "name": "Feeds",
      "allowanceMinutes": 5,
      "allDay": true,
      "sites": [
        { "catalogId": "ig-feed" }
      ]
    }
  ]
}
